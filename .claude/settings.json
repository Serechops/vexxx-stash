{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:/context-is-key/hooks/session-start.mjs\"",
            "timeout": 20000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:/context-is-key/hooks/pre-read.mjs\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:/context-is-key/hooks/post-tool.mjs\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
